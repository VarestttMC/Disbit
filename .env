# ─── ORBIT SMP BOT — ENVIRONMENT VARIABLES ───────────────────────────────────
# Copy this file to .env and fill in your values

# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord Application's Client ID — found in the Developer Portal
CLIENT_ID=your_client_id_here

# The Guild (Server) ID where commands will be registered
# Right-click your server name in Discord → Copy Server ID
GUILD_ID=your_guild_id_here

# Anthropic API Key — from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
